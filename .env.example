# ─────────────────────────────────────────────────────────────────────────────
# spectral-sr environment variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically at startup (never commit it to git).
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare R2 credentials ─────────────────────────────────────────────────
# Create an R2 API token at:
#   Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Grant "Object Read & Write" on your bucket.

R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# Your Cloudflare account ID is in the URL when you open the R2 dashboard:
#   https://dash.cloudflare.com/<ACCOUNT_ID>/r2
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Destination bucket (must already exist in your R2 account)
R2_BUCKET_NAME=spectral-reconstruction-experiments

# ── API server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# Optional bearer token to protect all API endpoints.
# Leave empty to run without authentication.
API_KEY=

# ── Data layout on the RunPod volume (or in R2) ───────────────────────────────
# Mount your RunPod network volume at /data.
# Expected structure (all can be r2:// keys too):
#
#   /data/
#     hyperion_train_npy/      ← Hyperion patches used for training
#     hyperion_val_npy/        ← Hyperion patches used for validation
#     hyperion_test_npy/       ← Hyperion patches used for testing
#     landsat_train_npy/       ← Landsat patches used for training
#     landsat_val_npy/         ← Landsat patches used for validation
#     landsat_test_npy/        ← Landsat patches used for testing
#     propertiesH_metadata.txt ← Hyperion wavelength metadata
#     propertiesL8_metadata.txt← Landsat-8 wavelength metadata
#     Models/                  ← Pre-trained model checkpoints (.pt)
