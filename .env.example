# ─────────────────────────────────────────────────────────────────────────────
# spectral-sr environment variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare R2 (S3-compatible) ────────────────────────────────────────────
# Create an API token at https://dash.cloudflare.com → R2 → Manage API tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# Endpoint URL format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://db79fd90f3dfd68702afa1f74d455523.r2.cloudflarestorage.com

# Destination bucket (must exist in your R2 account)
R2_BUCKET_NAME=spectral-reconstruction-experiments

# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# Optional: set a bearer token to protect the API endpoints.
# Leave empty to run without authentication.
API_KEY=

# ── Data paths (used when running inside Docker/RunPod) ───────────────────────
# Mount your RunPod network volume at /data and organise as:
#   /data/
#     hyperion_train_npy/
#     hyperion_val_npy/
#     hyperion_test_npy/
#     landsat_train_npy/
#     landsat_val_npy/
#     landsat_test_npy/
#     propertiesH_metadata.txt
#     propertiesL8_metadata.txt
#     Models/          ← pre-trained checkpoints
