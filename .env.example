# ─────────────────────────────────────────────────────────────────────────────
# spectral-sr environment variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically at startup (never commit it to git).
# All variables are prefixed with SPECTRAL_RECONSTRUCTION_.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare R2 credentials ─────────────────────────────────────────────────
# Create an R2 API token at:
#   Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Grant "Object Read & Write" on your buckets.

SPECTRAL_RECONSTRUCTION_R2_ACCESS_KEY_ID=your_r2_access_key_id_here
SPECTRAL_RECONSTRUCTION_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# Your Cloudflare account ID is in the URL when you open the R2 dashboard:
#   https://dash.cloudflare.com/<ACCOUNT_ID>/r2
SPECTRAL_RECONSTRUCTION_R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Data bucket (models, datasets — must already exist in your R2 account)
SPECTRAL_RECONSTRUCTION_R2_BUCKET_NAME=spectral-reconstruction-data-ena

# Experiments bucket (training/reconstruction outputs)
SPECTRAL_RECONSTRUCTION_R2_BUCKET_NAME_EXPERIMENTS=spectral-reconstruction-experiments

# ── API server ────────────────────────────────────────────────────────────────
# Set automatically in Docker images via APP_VERSION at build time.
# Override at runtime to test a different label without rebuilding.
# SPECTRAL_RECONSTRUCTION_SPECTRAL_SR_VERSION=1.2.3

SPECTRAL_RECONSTRUCTION_HOST=0.0.0.0
SPECTRAL_RECONSTRUCTION_PORT=8000
SPECTRAL_RECONSTRUCTION_WORKERS=1
SPECTRAL_RECONSTRUCTION_LOG_LEVEL=info

# Optional bearer token to protect all API endpoints.
# Leave empty to run without authentication.
SPECTRAL_RECONSTRUCTION_API_KEY=

# ── Data layout on the RunPod volume (or in R2) ───────────────────────────────
# Mount your RunPod network volume at /data.
# Expected structure (all can be r2:// keys too):
#
#   Bucket: spectral-reconstruction-data-ena  (objects at bucket root)
#     hyperion_train_npy/      ← Hyperion training patches (64×64×175)
#     hyperion_val_npy/        ← Hyperion validation patches (upload if missing)
#     hyperion_test_npy/       ← Hyperion test patches
#     landsat_train_npy/       ← Landsat training patches (64×64×7)
#     landsat_val_npy/         ← Landsat validation patches (upload if missing)
#     landsat_test_npy/        ← Landsat test patches
#     Models/                  ← Pre-trained model checkpoints (.pt)
#     ALI_envi_ascii.txt       ← Band response metadata
#
#   Bucket: spectral-reconstruction-experiments  (experiment outputs)
#     <experiment_name>/       ← outputs written here by training/reconstruction jobs
